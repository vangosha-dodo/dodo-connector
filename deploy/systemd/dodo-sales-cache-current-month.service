[Unit]
Description=Warm Dodo Bridge current-month sales summary cache
After=dodo-bridge.service
Wants=dodo-bridge.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/dodo-chatgpt-bridge
ExecStart=/home/ubuntu/dodo-chatgpt-bridge/.venv/bin/python scripts/refresh_sales_summary_cache.py --preset current-month --cache-mode auto --timeout 1200
