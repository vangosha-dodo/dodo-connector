[Unit]
Description=Refresh Dodo Bridge sales summary cache
After=dodo-bridge.service
Wants=dodo-bridge.service

[Service]
Type=oneshot
User=ubuntu
WorkingDirectory=/home/ubuntu/dodo-chatgpt-bridge
ExecStart=/home/ubuntu/dodo-chatgpt-bridge/.venv/bin/python scripts/refresh_sales_summary_cache.py --preset yesterday
