DODO_BRIDGE_API_KEYS=change-me
DODO_BRIDGE_TOOL_REGISTRY_PATH=configs/tools.example.yaml
DODO_BRIDGE_POLICY_PATH=configs/policy.example.yaml
DODO_BRIDGE_AUDIT_DB_PATH=data/bridge.sqlite3

DODO_BASE_URL=https://api.dodois.io
DODO_COUNTRY=ru
DODO_ACCESS_TOKEN=
DODO_DATA_MAX_PERIOD_DAYS=92
DODO_DATA_DEFAULT_TAKE=500
DODO_DATA_MAX_TAKE=1000
DODO_DATA_DEFAULT_MAX_PAGES=5
DODO_DATA_MAX_PAGES=20
DODO_DATA_MAX_ROWS=5000
DODO_PIZZERIAS_PATH=configs/pizzerias.generated.json

SUPERSET_BASE_URL=
SUPERSET_USERNAME=
SUPERSET_PASSWORD=
SUPERSET_ACCESS_TOKEN=
SUPERSET_SESSION_COOKIES_PATH=
SUPERSET_BROWSER_HELPER_COMMAND=node scripts/superset_chart_data.mjs
SUPERSET_BROWSER_COMMAND_TIMEOUT_SECONDS=180
SUPERSET_DASHBOARD_URL=https://analytics.dodois.io/superset/dashboard/p/LO35qvPb3D9/
SUPERSET_SESSION_FILES=/home/ubuntu/.openclaw/secret/officemanager_app_session.json,/home/ubuntu/.openclaw/secret/officemanager_session.json,/home/ubuntu/.openclaw/secret/admin_dodois_session.json

# Optional web-based Dodo IS OfficeManager/admin authorization helper.
# On the Ubuntu server this helper can reuse the same secret/session paths that
# OpenClaw used, while the bridge provides a small MFA-code web form.
DODO_AUTH_HELPER_COMMAND=node scripts/dodo_auth_flow.mjs
DODO_AUTH_COMMAND_TIMEOUT_SECONDS=180
DODO_AUTH_CHROME_PATH=/home/ubuntu/.cache/ms-playwright/chromium-1223/chrome-linux64/chrome
DODO_AUTH_SECRET_DIR=/home/ubuntu/.openclaw/secret
DODO_AUTH_TMP_DIR=/home/ubuntu/.openclaw/workspace/tmp

# Optional Dodo Knowledge Base / dodopizza.info authorization helper.
# It reuses OpenClaw Dodo credentials and mailbox settings, but stores a
# separate KB session file for read-only knowledge-base access.
DODO_KB_AUTH_HELPER_COMMAND=node scripts/dodo_kb_auth_flow.mjs
DODO_KB_AUTH_COMMAND_TIMEOUT_SECONDS=300
DODO_KB_BASE_URL=https://dodopizza.info
DODO_KB_AUTH_SESSION_FILE=dodopizza_info_session.json
DODO_KB_AUTH_MAIL_AUTH_FILE=/home/ubuntu/.openclaw/dodo/mail.ru_auth.json

# Internal Google Sheets automation. These endpoints are not exported to the
# ChatGPT Action schema. Keep writes disabled until a dry-run diff is reviewed.
DODO_OFFICE_MANAGER_HELPER_COMMAND=.venv/bin/python scripts/dodo_office_manager_reports.py
DODO_OFFICE_MANAGER_COMMAND_TIMEOUT_SECONDS=300
AUTOMATION_GOOGLE_SHEETS_WRITE_ENABLED=false
COURIER_PAYROLL_SPREADSHEET_ID=1eq81n7NL7hgmSYYm6RRwA1-zlRnsBeXX0QW7uuN2dHU
